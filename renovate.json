{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "schedule": ["before 8am on wednesday"],
   "packageRules": [
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    },
    {
      "matchManagers": ["cargo"],
      "matchPackagePatterns": ["^agent_provider"],
      "groupName": "agent providers",
      "groupSlug": "agent-providers",
      "separateMultipleMajor": true
    },
    {
      "matchManagers": ["cargo"],
      "matchPackagePatterns": ["^ui-crates"],
      "groupName": "ui",
      "groupSlug": "ui-crates",
      "separateMultipleMajor": true
    }
  ]
}
