{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "schedule": ["before 8am on wednesday"],
   "packageRules": [
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    },
    {
      "matchManagers": ["cargo"],
      "groupName": "tree-sitter grammars",
      "groupSlug": "tree-sitter",
      "matchPackageNames": [
      "/^tree-sitter/"
     ]
    }
  ]
}
