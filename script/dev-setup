#!/usr/bin/env bash
# dev-setup — Initialize local development environment.
#
# Clones submodules, generates the `.cargo/config.toml` with local
# path overrides so that vendored deps resolve without network fetches.

set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "==> Initializing submodules..."
git -C "$ROOT" submodule update --init --recursive

echo ""
echo "==> Generating .cargo/config.toml with local path patches..."
mkdir -p "$ROOT/.cargo"

# Generate config.toml with patches for all remaining git deps that have
# vendored copies. The root Cargo.toml already has [patch] sections, but
# this ensures .cargo/config.toml is in sync for tools that read it.
cat > "$ROOT/.cargo/config.toml" << 'CONFIG'
# Auto-generated by script/dev-setup
# Maps external git deps to local vendored copies.

[patch."https://github.com/Far-Beyond-Pulsar/WGPUI"]
gpui-ce = { path = "crates/ui/wgpui" }

[patch."https://github.com/Far-Beyond-Pulsar/WGPUI-Component"]
ui = { path = "crates/ui/wgpui-component/crates/ui" }
ui-macros = { path = "crates/ui/wgpui-component/crates/ui-macros" }

[patch."https://github.com/Far-Beyond-Pulsar/Pulsar-Native"]
pulsar_std        = { path = "crates/core/pulsar_std" }
plugin_editor_api = { path = "crates/core/plugin_editor_api" }
ui_common         = { path = "crates/editor/ui_common" }
engine_backend    = { path = "crates/core/engine_backend" }
engine_state      = { path = "crates/core/engine_state" }
pulsar_reflection = { path = "crates/core/pulsar_reflection" }
pulsar_std_bundle = { path = "crates/core/pulsar_std_bundle" }
pulsar_bp_executor = { path = "crates/core/pulsar_bp_executor" }
CONFIG

echo "==> Done."
echo ""
echo "Build with: cargo build -p pulsar_engine"
